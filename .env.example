# Copy this to .env and fill in. .env is gitignored.
# These tokens are user-scoped (same across teams). Team-scoped values
# (PagerDuty team IDs, Jira JQL, Rollbar token, GitHub repo, Wiz project)
# live in teams.json instead.

# --- Report timezone ---
# IANA timezone name. When set, the monthly window boundaries are local
# midnight in this timezone (e.g. April 1 00:00 EDT) rather than UTC
# midnight. Match it to your PagerDuty/Jira account's timezone so the
# counts in the report align with what those UIs show. Leave unset for UTC.
REPORT_TIMEZONE=

# --- PagerDuty ---
# User Settings → User Settings → API Access → "Create API User Token"
# A read-only token is sufficient.
PAGERDUTY_TOKEN=

# --- Jira (Atlassian) ---
# https://id.atlassian.com/manage-profile/security/api-tokens → "Create API token"
# Used with your Atlassian email via HTTP Basic auth. The same token also
# authenticates Confluence calls (no separate token needed).
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=

# --- Wiz ---
# Settings → Service Accounts → Create. May require admin help.
# Auth URL and API URL are region-specific; defaults below are for the EU tenant.
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZ_API_URL=https://api.eu1.app.wiz.io/graphql

# --- Rollbar (account-level, optional) ---
# Used only to build links to Rollbar items in the report's top-3 list.
# This is the account slug shown in Rollbar URLs after `/a/` (open any
# Rollbar page and copy the segment between `/a/` and the next `/`).
# If empty, the report shows top-3 titles as plain text.
ROLLBAR_ACCOUNT_SLUG=

# --- GitHub ---
# Personal access token (or fine-grained token) with `repo` and
# `security_events` scopes. The org is the GitHub org that owns your
# team's repos.
GITHUB_TOKEN=
GITHUB_ORG=
