# Copy this to .env and fill in. .env is gitignored.
# These tokens are user-scoped (same across teams). Team-scoped values
# (PagerDuty team IDs, Jira JQL, Rollbar token, GitHub repo, Wiz project)
# live in teams.json instead.

# --- PagerDuty ---
# User Settings → User Settings → API Access → "Create API User Token"
# A read-only token is sufficient.
PAGERDUTY_TOKEN=

# --- Jira (Atlassian) ---
# https://id.atlassian.com/manage-profile/security/api-tokens → "Create API token"
# Used with your Atlassian email via HTTP Basic auth.
JIRA_BASE_URL=https://babbel.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=

# --- Wiz ---
# Settings → Service Accounts → Create. May require admin help.
# Auth URL is region-specific; the default below is for the EU tenant.
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token
WIZ_API_URL=https://api.eu1.app.wiz.io/graphql

# --- GitHub ---
# Personal access token (or fine-grained token) with `repo` and
# `security_events` scopes. The org is the GitHub org that owns your
# team's repos (Babbel uses lessonnine).
GITHUB_TOKEN=
GITHUB_ORG=lessonnine
